<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Edit Patient | Mediora</title>

    <link rel="stylesheet" href="/form.css">

    <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

</head>

<body>

    <!-- Navbar -->

    <nav class="navbar">

        <div class="logo">

            <i class="fa-solid fa-hospital"></i>

            <span>MEDIORA</span>

        </div>

        <div class="nav-links">

            <a href="/">Home</a>

            <a href="/addPatient">Add Patient</a>

            <a href="/patientDetails">Patients</a>

        </div>

    </nav>

    <!-- Form Section -->

    <div class="form-section">

        <!-- Left Panel -->

        <div class="left-panel">

            <div class="circle">

                <i class="fa-solid fa-user-pen"></i>

            </div>

            <h2>Update Patient Record</h2>

            <p>

                Modify patient details and keep hospital records
                accurate and up to date.

            </p>

        </div>

        <!-- Right Panel -->

        <div class="right-panel">

            <h1>Edit Patient</h1>

            <p class="subtitle">

                Update the patient information below.

            </p>

            <form action="/updatePatient/<%= patient._id %>" method="POST">

                <div class="input-group">

                    <i class="fa-solid fa-user"></i>

                    <input
                        type="text"
                        name="name"
                        value="<%= patient.name %>"
                        required>

                </div>

                <div class="input-group">

                    <i class="fa-solid fa-calendar"></i>

                    <input
                        type="datetime-local"
                        name="date"
                        value="<%= new Date(patient.date).toISOString().slice(0,16) %>"
                        required>

                </div>

                <div class="input-group">

                    <i class="fa-solid fa-stethoscope"></i>

                    <input
                        type="text"
                        name="illness"
                        value="<%= patient.illness %>"
                        required>

                </div>

                <button type="submit">

                    <i class="fa-solid fa-floppy-disk"></i>
                    Update Patient

                </button>

            </form>

        </div>

    </div>

</body>

</html>